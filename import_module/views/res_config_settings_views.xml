<odoo>
  <record id="stock_settings_skip_import_check" model="ir.ui.view">
    <field name="name">stock.settings.skip.import.check</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//app[@name='stock']" position="inside">
        <block title="Costos en destino">
          <setting string="Permitir costos en destino sin Importación"
            help="Permite crear costos en destino desde factura aunque no tenga Importación asociada.">
            <field name="penta_skip_import_check_landed_cost"/>
          </setting>
        </block>
      </xpath>

    </field>
  </record>
  <record id="res_config_settings_view_form_import" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.inherit.magic.note
    </field>
    <field name="model">res.config.settings</field>
    <field name="priority" eval="60" />
    <field name="inherit_id" ref="l10n_ec_account_penta.res_config_settings_view_form_penta" />
    <field name="arch" type="xml">
      <xpath expr="//app[@name='l10n_ec_account_penta']" position="inside">
        <block title="Configuración importaciones" id="import_configuration">

          <setting id="calculate_customs_taxes"
            help="Si está activo, se habilita el cálculo de impuestos en Costos en destino.">

            <field name="penta_calculate_customs_taxes" />

          </setting>

        </block>

      </xpath>
    </field>
  </record>
  <!-- Menu for the settings -->
  <menuitem
    id="menu_import_module_root"
    name="Importaciones"
    web_icon="import_module,static/description/icon.png" />
</odoo>